{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Requisições",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "lab_requests_total", "refId": "A"}],
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "Erros",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "lab_errors_total", "refId": "A"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 0}
    },
    {
      "type": "stat",
      "title": "Uptime da aplicação",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "lab_process_uptime_seconds", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 0}
    },
    {
      "type": "stat",
      "title": "Banco disponível",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "lab_db_available", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "NÃO", "color": "red"}, "1": {"text": "SIM", "color": "green"}}}],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 7}
    },
    {
      "type": "stat",
      "title": "Erros de banco",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "lab_db_errors_total", "refId": "A"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 7}
    },
    {
      "type": "stat",
      "title": "Última consulta ao banco",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "lab_db_query_duration_seconds", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]}}, "overrides": []},
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 7}
    },
    {
      "type": "timeseries",
      "title": "Taxa de requisições",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(lab_requests_total[1m])", "legendFormat": "req/s", "refId": "A"}],
      "gridPos": {"h": 9, "w": 8, "x": 0, "y": 13}
    },
    {
      "type": "timeseries",
      "title": "Taxa de erros",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(lab_errors_total[1m])", "legendFormat": "erros/s", "refId": "A"}],
      "gridPos": {"h": 9, "w": 8, "x": 8, "y": 13}
    },
    {
      "type": "timeseries",
      "title": "Operações e erros no banco",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(lab_db_queries_total[1m])", "legendFormat": "consultas/s", "refId": "A"},
        {"expr": "rate(lab_db_errors_total[1m])", "legendFormat": "erros/s", "refId": "B"}
      ],
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 13}
    },
    {
      "type": "stat",
      "title": "Sonda HTTP",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "probe_success{job=\"blackbox-http\"}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "FALHA", "color": "red"}, "1": {"text": "OK", "color": "green"}}}],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 6, "x": 0, "y": 22}
    },
    {
      "type": "stat",
      "title": "CPU do host",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1}, "overrides": []},
      "gridPos": {"h": 7, "w": 6, "x": 6, "y": 22}
    },
    {
      "type": "stat",
      "title": "Memória disponível",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 * node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1}, "overrides": []},
      "gridPos": {"h": 7, "w": 6, "x": 12, "y": 22}
    },
    {
      "type": "stat",
      "title": "Disco raiz disponível",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 * node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1}, "overrides": []},
      "gridPos": {"h": 7, "w": 6, "x": 18, "y": 22}
    },
    {
      "type": "logs",
      "title": "Logs de erro da aplicação",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "{compose_service=\"app\"} | json | level=\"error\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 29}
    }
  ],
  "refresh": "5s",
  "schemaVersion": 41,
  "tags": ["observabilidade", "portfolio"],
  "time": {"from": "now-15m", "to": "now"},
  "title": "Observability Lab - Visão Operacional",
  "uid": "observability-lab",
  "version": 4
}
